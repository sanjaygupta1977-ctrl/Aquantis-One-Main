# AQUANTIS Production Environment Variables
# Copy this file to .env.production and fill in your values

# ====== DIGITALOCEAN DEPLOYMENT ======
DOCKER_REGISTRY=your-dockerhub-username
VITE_API_URL=https://api.aquantis-prod.io
CORS_ORIGIN=https://aquantis-prod.io

# ====== DATABASE ======
DB_PASSWORD=your-secure-password-here-min-16-chars
DATABASE_URL=postgresql://aquantis:${DB_PASSWORD}@postgres:5432/aquantis

# ====== AUTHENTICATION ======
JWT_SECRET=your-jwt-secret-min-32-chars-use-openssl-rand-hex-32
JWT_EXPIRY=7d

# ====== APPLICATION ======
NODE_ENV=production
LOG_LEVEL=info
PORT=5000

# ====== SECURITY ======
API_RATE_LIMIT=1000
SESSION_SECRET=your-session-secret-min-32-chars
ENCRYPTION_KEY=your-encryption-key-min-32-chars

# ====== OPTIONAL: EMAIL SERVICE ======
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@aquantis-prod.io

# ====== OPTIONAL: MONITORING ======
SENTRY_DSN=https://your-sentry-key@sentry.io/your-project-id
DATADOG_API_KEY=your-datadog-api-key

# ====== OPTIONAL: STORAGE (S3) ======
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=aquantis-prod-backups

# ====== DEPLOYMENT ======
DEPLOYMENT_ENV=production
DEPLOYMENT_REGION=sfo3
BACKUP_ENABLED=true
AUTO_UPDATES=true
